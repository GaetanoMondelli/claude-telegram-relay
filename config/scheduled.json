        },
        "crypto": {
          "enabled": true,
          "tokens": ["QNT"]
        },
        "calendar": {
          "enabled": true
        },
        "email": {
          "enabled": true,
          "maxEmails": 5
        },
        "goals": {
          "enabled": true
        }
      },
      "message_style": "concise"
    }
  ]
}
